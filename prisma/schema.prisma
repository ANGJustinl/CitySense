generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SourceConnector {
  id              String    @id @default(cuid())
  name            String    @unique
  type            String
  status          String
  enabled         Boolean   @default(true)
  cooldownSeconds Int       @default(60)
  config          Json?
  lastRunId       String?
  lastRunAt       DateTime?
  lastSuccessAt   DateTime?
  lastErrorAt     DateTime?
  lastError       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model RawSourceItem {
  id                   String   @id @default(cuid())
  source               String
  sourceKey            String   @unique
  sourceId             String?
  sourceUrl            String?
  title                String
  content              String?
  author               String?
  rawPayload           Json?
  parsedPayload        Json?
  city                 String?
  area                 String?
  publishedAt          DateTime?
  status               String
  itemType             String
  normalizedEntityType String?
  normalizedEntityId   String?
  ingestRunId          String?
  firstSeenAt          DateTime @default(now())
  lastSeenAt           DateTime @default(now())
  createdAt            DateTime @default(now())

  @@index([source])
  @@index([city])
  @@index([ingestRunId])
}

model Event {
  id          String   @id @default(cuid())
  sourceKey   String?  @unique
  title       String
  description String?
  city        String
  area        String?
  address     String?
  lat         Float?
  lng         Float?
  startTime   DateTime?
  endTime     DateTime?
  tags        String[]
  source      String?
  sourceUrl   String?
  imageUrl    String?
  imageSource String?
  trendScore  Float    @default(0)
  confidence  Float    @default(0)
  qualityScore Float    @default(50)
  qualityFlags String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([city])
  @@index([area])
  @@index([startTime])
  @@index([qualityScore])
}

model Venue {
  id          String   @id @default(cuid())
  sourceKey   String?  @unique
  name        String
  description String?
  city        String
  area        String?
  address     String?
  lat         Float?
  lng         Float?
  tags        String[]
  priceLevel  Int?
  quietness   Int?
  popularity  Int?
  source      String?
  sourceUrl   String?
  imageUrl    String?
  imageSource String?
  trendScore  Float    @default(0)
  confidence  Float    @default(0)
  qualityScore Float    @default(50)
  qualityFlags String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([city])
  @@index([area])
  @@index([qualityScore])
}

model CitySignal {
  id         String   @id @default(cuid())
  city       String
  area       String?
  tag        String
  heatScore  Float
  source     String
  capturedAt DateTime
  metadata   Json?

  @@index([city])
  @@index([area])
  @@index([tag])
  @@index([capturedAt])
}

model IngestRun {
  id          String    @id @default(cuid())
  city        String
  area        String?
  keywords    String[]
  sources     String[]
  status      String
  requestedBy String?
  force       Boolean   @default(false)
  stats       Json?
  error       String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}

model TrafficSnapshot {
  id         String   @id @default(cuid())
  city       String
  originLat  Float
  originLng  Float
  destLat    Float
  destLng    Float
  mode       String
  distance   Int?
  duration   Int?
  congestion String?
  rawPayload Json?
  capturedAt DateTime @default(now())

  @@index([city])
  @@index([capturedAt])
}

model UserPreference {
  id             String   @id @default(cuid())
  userId         String   @unique
  interests      String[]
  mood           String?
  budget         String?
  metadata       Json?
  // 画像 MVP 快照元数据,便于 SQL 排查画像版本与稀疏度。
  // 完整画像快照(profileVersion/weights/recentExposure/topReasons)写在 metadata Json 列。
  profileVersion Int?
  signalCount    Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model RecommendationLog {
  id                String   @id @default(cuid())
  userId            String?
  input             Json
  recommendedRoutes Json
  feedback          Json?
  createdAt         DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model UserInteraction {
  id               String   @id @default(cuid())
  userId           String?
  recommendationId String?
  routeId          String?
  itemId           String?
  itemType         String?
  action           String
  weight           Float    @default(1)
  context          Json?
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([recommendationId])
  @@index([itemId])
  @@index([action])
  @@index([createdAt])
}

model RecommendationFeatureSnapshot {
  id               String   @id @default(cuid())
  recommendationId String
  candidateId      String
  candidateType    String
  ranker           String
  rankerVersion    String
  recallChannels   String[]
  features         Json
  score            Float
  position         Int
  createdAt        DateTime @default(now())

  @@index([recommendationId])
  @@index([candidateId])
  @@index([ranker])
}

model RecommendationFeedback {
  id                  String   @id @default(cuid())
  recommendationLogId String   @map("recommendation_log_id")
  routeId             String   @map("route_id")
  userId              String?  @map("user_id")
  sessionId           String?  @map("session_id")
  value               String
  reason              String?
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([recommendationLogId])
  @@index([routeId])
  @@index([userId])
  @@index([sessionId])
  @@index([value])
  @@index([createdAt])
  @@map("recommendation_feedbacks")
}
