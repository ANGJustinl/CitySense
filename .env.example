# Supabase Supavisor Session pooler, port 5432.
# Example:
# DATABASE_URL="postgres://prisma.[PROJECT_REF]:[PRISMA_PASSWORD]@[DB_REGION].pooler.supabase.com:5432/postgres"
DATABASE_URL=""
DATABASE_CONNECTION_LIMIT="1"
DATABASE_POOL_TIMEOUT="20"
REDIS_URL=""
AMAP_API_KEY=""
NEXT_PUBLIC_AMAP_JS_API_KEY=""
NEXT_PUBLIC_AMAP_SECURITY_JS_CODE=""
OPENAI_API_KEY=""
BILIBILI_MCP_URL=""
BILIBILI_MCP_TOKEN=""
XIAOHONGSHU_MCP_URL="http://localhost:18060/mcp"
XIAOHONGSHU_MCP_TOKEN=""
TRENDS_HUB_MCP_COMMAND="npx"
TRENDS_HUB_MCP_ARGS="-y mcp-trends-hub"
TRENDS_HUB_MCP_TOOLS="get_weibo_trending,get_zhihu_trending,get_toutiao_trending,get_thepaper_trending"
TRENDS_HUB_HIDDEN_FIELDS="cover"
TRENDS_HUB_MAX_ITEMS="30"
